# ═══════════════════════════════════════
# TemplateName — Production Environment
# ═══════════════════════════════════════

# ─── App ───
APP_NAME=TemplateName
APP_ENV=production
APP_KEY=base64:GENERATE_WITH_php_artisan_key:generate
APP_DEBUG=false
APP_URL=https://DOMAIN.RU
FRONTEND_URL=https://DOMAIN.RU

# ─── Database ───
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=templatename
DB_USERNAME=templatename
DB_PASSWORD=STRONG_PASSWORD_HERE

# ─── Redis ───
REDIS_HOST=redis
REDIS_PASSWORD=STRONG_REDIS_PASSWORD
REDIS_PORT=6379

# ─── Cache / Queue / Session ───
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

# ─── S3 Storage (для ZIP-файлов и изображений) ───
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ru-central1
AWS_BUCKET=templatename
AWS_ENDPOINT=https://storage.yandexcloud.net
AWS_USE_PATH_STYLE_ENDPOINT=true

# ─── ЮKassa ───
YUKASSA_SHOP_ID=
YUKASSA_SECRET_KEY=

# ─── Mail (Yandex) ───
MAIL_MAILER=smtp
MAIL_HOST=smtp.yandex.ru
MAIL_PORT=465
MAIL_ENCRYPTION=ssl
MAIL_USERNAME=hello@DOMAIN.RU
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=hello@DOMAIN.RU
MAIL_FROM_NAME=TemplateName

# ─── Telegram Bot (уведомления админу) ───
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── OpenAI (AI-подбор шаблона) ───
OPENAI_API_KEY=

# ─── Frontend URLs ───
NEXT_PUBLIC_API_URL=https://DOMAIN.RU
NEXT_PUBLIC_SITE_URL=https://DOMAIN.RU
