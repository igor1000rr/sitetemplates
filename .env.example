# ─── Приложение ───
APP_NAME=AITempl
APP_ENV=production
APP_KEY=base64:GENERATE_WITH_php_artisan_key_generate
APP_DEBUG=false
APP_URL=https://aitempl.ru

# ─── Админ (сидер) ───
# Если ADMIN_PASSWORD пуст — пароль генерируется случайно и выводится при db:seed.
ADMIN_EMAIL=admin@aitempl.ru
ADMIN_PASSWORD=

# ─── Фронтенд ───
NEXT_PUBLIC_API_URL=https://aitempl.ru
NEXT_PUBLIC_SITE_URL=https://aitempl.ru
# Внутренний URL API для серверного рендеринга (Docker)
API_URL=http://api:8000

# ─── База данных ───
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=aitempl
DB_USERNAME=aitempl
DB_PASSWORD=CHANGE_ME

# ─── Redis ───
REDIS_HOST=redis
REDIS_PASSWORD=CHANGE_ME
REDIS_PORT=6379

# ─── Очереди / Кэш / Сессии ───
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

# ─── ЮKassa ───
YUKASSA_SHOP_ID=
YUKASSA_SECRET_KEY=
YUKASSA_RETURN_URL=https://aitempl.ru/checkout/success

# ─── S3 (Timeweb Cloud / любой S3) ───
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ru-1
AWS_BUCKET=aitempl
AWS_ENDPOINT=https://s3.timeweb.cloud
AWS_URL=https://s3.timeweb.cloud/aitempl

# ─── Почта (Resend по SMTP) ───
# MAIL_PASSWORD = Resend API-ключ (re_...). На сервере приходит из секрета RESEND_API_KEY
# (см. workflow). Домен отправителя должен быть подтверждён в Resend (DNS: SPF/DKIM).
MAIL_MAILER=smtp
MAIL_HOST=smtp.resend.com
MAIL_PORT=587
MAIL_USERNAME=resend
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@aitempl.ru
MAIL_FROM_NAME=AITempl

# ─── Telegram-бот ───
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ADMIN_CHAT_ID=

# ─── AI Chat (OpenAI) ───
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ─── Аналитика ───
NEXT_PUBLIC_YM_ID=
NEXT_PUBLIC_GA_ID=

# ─── OAuth ───
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://aitempl.ru/api/auth/google/callback

YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_REDIRECT_URI=https://aitempl.ru/api/auth/yandex/callback

# ─── CORS ───
FRONTEND_URL=https://aitempl.ru

# ─── Sanctum ───
SANCTUM_STATEFUL_DOMAINS=aitempl.ru
