# ─── Приложение ───
APP_NAME=TemplateName
APP_ENV=production
APP_KEY=base64:GENERATE_WITH_php_artisan_key_generate
APP_DEBUG=false
APP_URL=https://templatename.ru

# ─── Фронтенд ───
NEXT_PUBLIC_API_URL=https://templatename.ru
NEXT_PUBLIC_SITE_URL=https://templatename.ru
# Внутренний URL API для серверного рендеринга (Docker)
API_URL=http://api:8000

# ─── База данных ───
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=templatename
DB_USERNAME=templatename
DB_PASSWORD=CHANGE_ME

# ─── Redis ───
REDIS_HOST=redis
REDIS_PASSWORD=CHANGE_ME
REDIS_PORT=6379

# ─── Очереди / Кэш / Сессии ───
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

# ─── ЮKassa ───
YUKASSA_SHOP_ID=
YUKASSA_SECRET_KEY=
YUKASSA_WEBHOOK_SECRET=
YUKASSA_RETURN_URL=https://templatename.ru/checkout/success

# ─── S3 (Timeweb Cloud / любой S3) ───
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ru-1
AWS_BUCKET=templatename
AWS_ENDPOINT=https://s3.timeweb.cloud
AWS_URL=https://s3.timeweb.cloud/templatename

# ─── Почта ───
MAIL_MAILER=smtp
MAIL_HOST=smtp.yandex.ru
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@templatename.ru
MAIL_FROM_NAME=TemplateName

# ─── Telegram-бот ───
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ADMIN_CHAT_ID=

# ─── AI Chat (OpenAI) ───
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ─── Аналитика ───
NEXT_PUBLIC_YM_ID=
NEXT_PUBLIC_GA_ID=

# ─── OAuth ───
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://templatename.ru/api/auth/google/callback

YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_REDIRECT_URI=https://templatename.ru/api/auth/yandex/callback

# ─── CORS ───
FRONTEND_URL=https://templatename.ru

# ─── Sanctum ───
SANCTUM_STATEFUL_DOMAINS=templatename.ru
