APP_NAME=AITempl
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=aitempl
DB_USERNAME=postgres
DB_PASSWORD=

CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ЮKassa
YUKASSA_SHOP_ID=
YUKASSA_SECRET_KEY=
YUKASSA_WEBHOOK_SECRET=

# S3 (Timeweb / Selectel / Yandex Cloud)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ru-1
AWS_BUCKET=aitempl
AWS_ENDPOINT=https://s3.timeweb.cloud
AWS_URL=https://aitempl.s3.timeweb.cloud
AWS_USE_PATH_STYLE_ENDPOINT=true

# Sanctum
SANCTUM_STATEFUL_DOMAINS=localhost:3000,aitempl.ru

# Mail (для уведомлений)
MAIL_MAILER=smtp
MAIL_HOST=smtp.yandex.ru
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=hello@aitempl.ru
MAIL_FROM_NAME=AITempl

# Telegram (уведомления админу)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# OpenAI (AI-подбор шаблонов, опционально)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Social Auth (OAuth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=${APP_URL}/api/auth/social/google/callback

YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_REDIRECT_URI=${APP_URL}/api/auth/social/yandex/callback

# Frontend URL (для OAuth redirect)
FRONTEND_URL=http://localhost:3000
